<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    package="learn.project.digitalnoteapp">

    <application
        android:allowBackup="true"
        android:icon="@drawable/icon"
        android:label="@string/app_name"
        android:roundIcon="@drawable/icon"
        android:supportsRtl="true"
        android:theme="@style/Theme.DigitalNoteApp"
        tools:targetApi="31">
         <activity
            android:name=".view.EditNoteActivity"
            android:exported="false"
            android:label="@string/title_activity_edit_details_note"
            android:theme="@style/Theme.DigitalNoteApp.NoActionBar" />
        <activity
            android:name=".view.SplashScreen"
            android:exported="true"
            android:theme="@style/Theme.DigitalNoteApp.NoActionBar">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name=".view.MainActivity"
            android:exported="true"
            android:theme="@style/Theme.DigitalNoteApp.NoActionBar"/>
    </application>

</manifest>