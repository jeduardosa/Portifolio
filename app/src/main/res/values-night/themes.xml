<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base NIGHT application theme. -->
    <style name="Theme.DigitalNoteApp.NIGHT" parent="Theme.MaterialComponents.DayNight.DarkActionBar">

        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/yellowLight</item>
        <item name="colorPrimaryVariant">@color/yellowPrimary</item>
        <item name="colorOnPrimary">@color/yellowDark</item>

        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/yellowPrimary</item>
        <item name="colorSecondaryVariant">@color/yellowDark</item>
        <item name="colorOnSecondary">@color/black</item>

        <!-- Status bar color. -->
        <item name="android:statusBarColor" tools:targetApi="l">?attr/colorPrimaryVariant</item>

        <!-- Customize your theme here. -->
        <item name="windowNoTitle">true</item>
        <item name="windowActionBar">false</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowContentOverlay">@null</item>
    </style>

    <style name="ProgressBar">
        <item name="colorOnPrimary">@color/yellowPrimary</item>
    </style>
</resources>